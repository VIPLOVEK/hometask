# HomeTask — Vercel Environment Variables
# Copy these to your Vercel project dashboard under Settings → Environment Variables
# Do NOT commit real values to git.

# User 1 credentials (e.g. your login)
USER1_NAME=yourname
USER1_PASS=YourSecurePassword1

# User 2 credentials (e.g. partner's login)
USER2_NAME=partnername
USER2_PASS=YourSecurePassword2

# Random secret for signing session tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
